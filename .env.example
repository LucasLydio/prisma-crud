# Postgres (recommended)
# Option A: single DATABASE_URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todo-list?schema=public"

# Option B: connection parts (if you prefer)
# POSTGRES_HOST="localhost"
# POSTGRES_PORT="5432"
# POSTGRES_USER="postgres"
# POSTGRES_PASSWORD="postgres"
# POSTGRES_DB="todo-list"

# JWT
JWT_SECRET="change-me"

# CORS
# Comma-separated list or "*" (supports wildcards like "https://*.myapp.com")
CORS_ORIGINS="*"
# CORS_ALLOW_CREDENTIALS="false"
